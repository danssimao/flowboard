branch="$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')"
if ! echo "$branch" | grep -qE '^(feat|fix|build|chore|ci|docs|perf|refactor|style|test)\/[a-z0-9._-]+$'; then
  echo "ERROR: Branch name '$branch' does not follow the pattern tipo/descricao"
  echo "Allowed types: feat|fix|build|chore|ci|docs|perf|refactor|style|test"
  exit 1
fi
